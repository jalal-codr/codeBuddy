<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Disable sandbox so we can spawn subprocesses and connect to localhost -->
    <key>com.apple.security.app-sandbox</key>
    <false/>

    <!-- Outbound network (localhost Ollama + devcompanion HTTP calls) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Read user-selected files (folder picker) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Read/write ~/  so devcompanion can write ~/.devcompanion/chunks.db -->
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
</dict>
</plist>
